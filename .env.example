# Copy this file to .env.local and fill in your credentials.
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Scorecard scanner (Gemini vision). Server-side ONLY — no VITE_ prefix, so it is
# never bundled into the browser. Get a free key at https://aistudio.google.com/apikey
# Also add this to the Vercel project env vars (Production + Preview).
GEMINI_API_KEY=your-gemini-api-key-here
# Optional model override (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
